PORT=3000
NODE_ENV=development

# Azure SQL connection
DB_SERVER=your-server.database.windows.net
DB_NAME=your-database
DB_USER=your-username
DB_PASSWORD=your-password

# JWT secret — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-with-64-char-random-hex

# Local dev SSL (ignored in production — Azure App Service handles HTTPS)
SSL_KEY_PATH=./ssl/server.key
SSL_CERT_PATH=./ssl/server.cert

# Allowed origins for CORS in development. In production both portals are served from the same origin.
CUSTOMER_PORTAL_URL=https://localhost:5173
EMPLOYEE_PORTAL_URL=https://localhost:5174

# Employee seed credentials. Used only by db/seed.js. Never committed.
SEED_EMPLOYEE_1_FULLNAME=John Smith
SEED_EMPLOYEE_1_USERNAME=jsmith
SEED_EMPLOYEE_1_PASSWORD=your-strong-password-here
SEED_EMPLOYEE_2_FULLNAME=Sarah Johnson
SEED_EMPLOYEE_2_USERNAME=sjohnson
SEED_EMPLOYEE_2_PASSWORD=your-strong-password-here
