PORT=3000
NODE_ENV=development

# Azure SQL — use the same eduboard server that hosts EventEase / FarmConnect
DB_SERVER=eduboard-server.database.windows.net
DB_NAME=PaymentsPortalDb
DB_USER=eduboard
DB_PASSWORD=replace-with-real-password

# JWT secret — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-with-64-char-random-hex

# Local dev SSL (ignored in production — Azure App Service handles HTTPS)
SSL_KEY_PATH=./ssl/server.key
SSL_CERT_PATH=./ssl/server.cert

# Customer portal origin (React dev server) — used by CORS allow-list
CUSTOMER_PORTAL_URL=https://localhost:5173
